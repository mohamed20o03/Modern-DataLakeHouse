# ====================================
# MinIO (S3-compatible Object Storage)
# ====================================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=changeme_in_production
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=changeme_in_production
MINIO_BUCKET_UPLOADS=staging-applicationarea
MINIO_BUCKET_WAREHOUSE=warehouse
MINIO_PORT_API=9000
MINIO_PORT_CONSOLE=9001

# ====================================
# RabbitMQ (Message Queue)
# ====================================
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=changeme_in_production
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_QUEUE_NAME=file.processing.queue

# ====================================
# Redis (Job Status Cache)
# ====================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6380
REDIS_PASSWORD=changeme_in_production
# Redis mode for ingestion-worker (async=non-blocking, sync=blocking)
WORKER_REDIS_MODE=async

# ====================================
# API Service (Spring Boot)
# ====================================
API_SERVICE_PORT=8080
SPRING_PROFILES_ACTIVE=prod

# ====================================
# PostgreSQL (Iceberg Catalog Database)
# ====================================
POSTGRES_HOST=catalog-postgres
POSTGRES_PORT=5432
POSTGRES_PORT_EXTERNAL=5433
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg_password
POSTGRES_DB=iceberg_catalog

# ====================================
# Iceberg REST Catalog
# ====================================
ICEBERG_REST_PORT=8181
ICEBERG_CATALOG_URI=http://iceberg-rest-catalog:8181
ICEBERG_WAREHOUSE=s3://warehouse
AWS_REGION=us-east-1

# ====================================
# Worker Configuration
# ====================================
# Number of concurrent message processing threads (1 for local, 5-10 for production)
WORKER_CONCURRENCY=2
# Storage backend: minio (local/dev) | s3 (production)
STORAGE_TYPE=minio
# Ingestion engine: spark | flink (future)
INGESTION_ENGINE=spark
# Query engine: spark
QUERY_ENGINE=spark
# Message consumer type: rabbitmq | kafka (future)
CONSUMER_TYPE=rabbitmq
# Redis mode for ingestion-worker: async | sync
WORKER_REDIS_MODE=async